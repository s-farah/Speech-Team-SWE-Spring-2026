"""
Step 1: Audio recording with threading.
This just gets the mic working in its own thread

Dont forget to install dependencies:
    pip install pyaudio

To test: just run this file, it will print "chunk recorded" every 2 seconds
to confirm audio is being captured correctly.
"""

import pyaudio
import wave
import io
import threading
import queue
import time


CHUNK = 1024          # frames per read (how much mic data we grab at once)
RATE = 16000          # whisper expects 16000?
CHANNELS = 1          
CHUNK_SECONDS = 2     # how long each audio clip is before we process it
FORMAT = pyaudio.paInt16

# this queue will hold recorded audio chunks
# Thread 1 puts chunks in, Thread 2 (Whisper - coming later) pulls them out
audio_queue = queue.Queue()


def record_audio():
    """
    Thread 1: Continuously records audio from the mic.
    Every CHUNK_SECONDS puts frames into a WAV-formatted for Whisper API
    adds to audio_queue.
    """
    p = pyaudio.PyAudio()

    stream = p.open(
        format=FORMAT,
        channels=CHANNELS,
        rate=RATE,
        input=True,
        frames_per_buffer=CHUNK
    )

    print("Mic is recording...")

    frames_per_chunk = int(RATE / CHUNK * CHUNK_SECONDS)  # how many reads = 2 seconds

    while True:
        frames = []

        # collect 2 seconds of audio frames
        for _ in range(frames_per_chunk):
            data = stream.read(CHUNK, exception_on_overflow=False)
            frames.append(data)

        # put frames into a WAV bytes object 
        wav_buffer = io.BytesIO()
        with wave.open(wav_buffer, 'wb') as wf:
            wf.setnchannels(CHANNELS)
            wf.setsampwidth(p.get_sample_size(FORMAT))
            wf.setframerate(RATE)
            wf.writeframes(b''.join(frames))

        wav_buffer.seek(0)  # rewind 

        audio_queue.put(wav_buffer)


def process_audio():
    """
    Thread 2 placeholder: Pulls audio chunks from the queue.
    Right now just confirms it received the chunk.
    This is where Whisper transcription will go.
    """
    while True:
        audio_chunk = audio_queue.get()  # blocks until a chunk is available
